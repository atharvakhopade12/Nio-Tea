PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_this
ADMIN_JWT_EXPIRE=1d

# OTP Service (MSG91)
OTP_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@niotea.com
ADMIN_PASSWORD=Admin@123

# Supabase (backend service role key + storage buckets)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_PRODUCTS_BUCKET=products
SUPABASE_CONTENT_BUCKET=content

# Node environment
NODE_ENV=development

# CORS Origin (set this to your frontend URL in production)
CLIENT_URL=http://localhost:5173
