PORT=5000
MONGO_URI=mongodb://localhost:27017/nio-tea
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
ADMIN_JWT_SECRET=your_admin_jwt_secret_change_this
ADMIN_JWT_EXPIRE=1d

# OTP Service (Twilio example - replace with your credentials)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Fast2SMS alternative (Indian SMS service)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@niotea.com
ADMIN_PASSWORD=Admin@123

# Supabase (backend service role key)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Node environment
NODE_ENV=development

# CORS Origin (set this to your frontend URL in production)
CLIENT_URL=http://localhost:5173
